const isPremiumAdultUser = (user) => {
  const isAdult = user.age >= 18;
  const hasPremium = user.subscriptionType === 'premium';
  return isAdult && hasPremium;
};

if (isPremiumAdultUser(user)) {
  hideAllAdvertisements();
}

